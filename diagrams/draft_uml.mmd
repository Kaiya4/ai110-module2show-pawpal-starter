classDiagram
    class Owner {
        +name: str
        +pets: list
        +available_minutes: int
        +add_pet(pet: Pet)
        +set_available_time(minutes: int)
    }

    class Pet {
        +name: str
        +species: str
        +tasks: list
        +add_task(task: Task)
        +remove_task(task: Task)
    }

    class Task {
        +name: str
        +duration: int
        +priority: str
        +edit_task(duration: int, priority: str)
    }

    class Scheduler {
        +owner: Owner
        +daily_plan: list
        +generate_plan()
        +explain_plan()
    }

    Owner "1" *-- "*" Pet : owns
    Pet "1" *-- "*" Task : has
    Scheduler --> Owner : uses